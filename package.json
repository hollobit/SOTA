{
  "name": "sota-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Build pipeline for the LLM Benchmark SOTA Dashboard Tailwind CSS.",
  "scripts": {
    "build:css": "tailwindcss -i dashboard/src/tailwind.css -o dashboard/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i dashboard/src/tailwind.css -o dashboard/css/tailwind.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "3.4.17"
  }
}
