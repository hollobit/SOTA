  "benchmarks": [
    {"id": "med_halt", "name": "Med-HALT (Hallucination Test)", "category": "medical-safety", "metric": "accuracy", "description": "Multinational medical exam-derived hallucination benchmark — reasoning + memory hallucination tests for medical LLMs. Med-HALT consortium (paper 2023.07)."},
    {"id": "medhallu", "name": "MedHallu (Hallucination Detection)", "category": "medical-safety", "metric": "accuracy", "description": "First benchmark for medical hallucination detection — 10K QA pairs from PubMedQA with systematically generated hallucinated answers (MIT Media Lab 2025)"},
    {"id": "medhallbench", "name": "MedHallBench", "category": "medical-safety", "metric": "score", "description": "Comprehensive medical hallucination evaluation — expert-validated case scenarios + medical databases. UCSD 2024-12"},
    {"id": "medsafetybench", "name": "MedSafetyBench (AMA principles)", "category": "medical-safety", "metric": "harmful_compliance", "description": "Medical safety benchmark built on 9 AMA medical-doctor ethics principles. 450 verified synthetic prompts (ill-intentioned clinician), measures harmful compliance rate (lower=safer). NeurIPS 2024"},
    {"id": "medriskeval", "name": "MedRiskEval", "category": "medical-safety", "metric": "score", "description": "Medical risk evaluation benchmark — user-perspective patient safety in healthcare LLM use"},
    {"id": "csedb_safety", "name": "CSEDB Safety", "category": "medical-safety", "metric": "score", "description": "Clinical Safety-Effectiveness Dual-Track Benchmark — 30 metrics: critical illness recognition, guideline adherence, medication safety. Average safety 54.7%, drops 13.3% in high-risk scenarios. Nature npj Digital Medicine 2025"},
    {"id": "csedb_effectiveness", "name": "CSEDB Effectiveness", "category": "medical", "metric": "score", "description": "CSEDB effectiveness track. Average effectiveness 62.3%"},
    {"id": "patientsafebench", "name": "PatientSafeBench", "category": "medical-safety", "metric": "safety", "description": "Patient-use safety benchmark — measures LLM safety when used directly by patients (vs clinicians). OpenReview 2025"},
    {"id": "craft_md", "name": "CRAFT-MD (Conversational Reasoning)", "category": "medical-safety", "metric": "factual_accuracy", "description": "Conversational reasoning eval — simulates AI-agent patient interactions, measures factual accuracy in patient-LLM conversations"},
    {"id": "medic_eval", "name": "MEDIC (Clinical LLM Indicators)", "category": "medical", "metric": "score", "description": "Comprehensive evaluation of Leading Indicators for Clinical LLMs — multidimensional 5 evaluation axes. Yale + Google 2024-09"},

    {"id": "rexrank_radgraph_f1", "name": "ReXrank RadGraph-F1", "category": "medical-imaging", "metric": "f1", "description": "Radiology report generation entity+relation F1 from RadGraph schema. Standard ReXrank metric — captures clinical entities and their relationships"},
    {"id": "rexrank_bertscore", "name": "ReXrank BERTScore", "category": "medical-imaging", "metric": "bertscore", "description": "Radiology report generation semantic similarity (BERTScore) on MIMIC-CXR + ReXGradient + IU-Xray + CheXpert Plus"},
    {"id": "rexrank_radcliq", "name": "ReXrank RadCliQ", "category": "medical-imaging", "metric": "radcliq", "description": "RadCliQ composite radiology-report quality score combining BLEU + BERTScore + RadGraph-F1"},
    {"id": "rexrank_green", "name": "ReXrank GREEN", "category": "medical-imaging", "metric": "green", "description": "GREEN metric — clinical relevance + factuality combined for chest X-ray report generation"},
    {"id": "rexrank_finerad", "name": "ReXrank FineRadScore", "category": "medical-imaging", "metric": "score", "description": "Fine-grained radiology report score — finding-level error detection"},
    {"id": "chexpert_f1", "name": "CheXpert F1 (14-finding)", "category": "medical-imaging", "metric": "f1", "description": "CheXpert label F1 across 14 chest X-ray findings — standard radiology auto-eval metric. Stanford AIMI"},
    {"id": "rexgrad_acc", "name": "ReXGradient Test Accuracy", "category": "medical-imaging", "metric": "accuracy", "description": "Largest test dataset (10,000 studies) for radiology report generation eval. ReXrank's primary holdout"},

    {"id": "vqa_rad", "name": "VQA-RAD", "category": "medical-imaging", "metric": "accuracy", "description": "Radiology VQA — 315 images, 3,515 questions, 517 possible answers. Standard medical VQA benchmark since 2018"},
    {"id": "slake_vqa", "name": "SLAKE-VQA (Bilingual)", "category": "medical-imaging", "metric": "accuracy", "description": "Bilingual EN-CN medical VQA — 642 images + 14K questions across radiology/CT/MRI"},
    {"id": "path_vqa", "name": "Path-VQA", "category": "medical-imaging", "metric": "accuracy", "description": "Pathology VQA — 32K Q-A pairs from pathology textbook images. Closed + open question splits"},
    {"id": "pmc_vqa", "name": "PMC-VQA", "category": "medical-imaging", "metric": "accuracy", "description": "Large-scale medical VQA from PubMed Central figures + captions. PMC-VQA-Test 2,096 image-Q pairs"},

